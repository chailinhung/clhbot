<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>菜單載入中...</title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <style>
        body { font-family: -apple-system, sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background: #f4f7f9; }
        .loader { border: 4px solid #f3f3f3; border-top: 4px solid #06C755; border-radius: 50%; width: 45px; height: 45px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="loader"></div>
    <script>
        const LIFF_ID = '2010205613-GBhWoaIf'; 
        // 🚀 已移除不需使用的 GAS 網址變數，此頁保持純前端運行，直接將資料交棒給下一頁的 Firestore SDK 處理。

        async function init() {
            // 設定 5 秒強制跳轉定時器 (Timeout)
            const timeoutPromise = new Promise((resolve) => {
                setTimeout(() => {
                    console.log('LIFF Timeout: Redirecting with default name...');
                    resolve({ isTimeout: true });
                }, 5000);
            });

            // LIFF 處理邏輯
            const liffPromise = (async () => {
                try {
                    await liff.init({ liffId: LIFF_ID });
                    if (!liff.isLoggedIn()) {
                        liff.login({ redirectUri: window.location.href });
                        return { waitLogin: true };
                    }

                    let userName = "";
                    // 第一層：嘗試極速解碼 (ID Token)
                    const idToken = liff.getDecodedIDToken();
                    if (idToken && idToken.name) {
                        userName = idToken.name;
                    } else {
                        // 第二層：連網抓取 (getProfile)
                        const profile = await liff.getProfile();
                        userName = profile.displayName;
                    }
                    return { userName: userName || "" };

                } catch (e) {
                    console.error('LIFF Error:', e);
                    return { userName: "" };
                }
            })();

            // 競賽：看是 LIFF 先跑完還是 5 秒先到
            const result = await Promise.race([liffPromise, timeoutPromise]);

            if (result && result.waitLogin) return; // 如果正在跳轉登入，則不執行後續

            const urlParams = new URLSearchParams(window.location.search);
            const finalName = result.userName || "";
            urlParams.set('uName', finalName);

            // 根據點餐類型動態跳轉至對應的 GitHub 頁面 (order_ui 或 order_drink_ui)
            const type = (urlParams.get('type') || "").toUpperCase();
            const currentPath = window.location.pathname;
            const dirPath = currentPath.substring(0, currentPath.lastIndexOf('/') + 1);
            const pageFile = (type === 'DRINK') ? 'order_drink_ui.html' : 'order_ui.html';
            const targetUrl = window.location.origin + dirPath + pageFile + '?' + urlParams.toString();

            window.location.replace(targetUrl);
        }
        window.onload = init;
    </script>
</body>
</html>
