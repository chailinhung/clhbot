<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>菜單載入中...</title>
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <style>
        body { font-family: -apple-system, sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background: #f4f7f9; }
        .loader { border: 4px solid #f3f3f3; border-top: 4px solid #06C755; border-radius: 50%; width: 45px; height: 45px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="loader"></div>
    <script>
        const LIFF_ID = '2010205613-GBhWoaIf'; 

        async function init() {
            // 5 秒強制超時保護
            const timeoutPromise = new Promise(resolve => setTimeout(() => resolve({ userName: "" }), 5000));

            const liffPromise = (async () => {
                try {
                    await liff.init({ liffId: LIFF_ID });
                    if (!liff.isLoggedIn()) {
                        liff.login({ redirectUri: window.location.href });
                        return { waitLogin: true };
                    }

                    let userName = "";
                    // 第一層：嘗試極速解碼 (ID Token)
                    const idToken = liff.getDecodedIDToken();
                    if (idToken && idToken.name) {
                        userName = idToken.name;
                    } else {
                        // 第二層：連網抓取 (getProfile)
                        const profile = await liff.getProfile();
                        userName = profile.displayName;
                    }
                    return { userName: userName || "" };

                } catch (e) {
                    console.error('LIFF Error:', e);
                    return { userName: "" };
                }
            })();

            // 競賽：看是 LIFF 先跑完還是 5 秒先到
            const result = await Promise.race([liffPromise, timeoutPromise]);

            if (result && result.waitLogin) return; // 如果正在跳轉登入，則不執行後續

            // ── 🌐 核心優化：解析當前網址參數，直接在 GitHub 本地完成跳轉 ──
            const urlParams = new URLSearchParams(window.location.search);
            const finalName = result.userName || "";
            urlParams.set('uName', finalName); // 填入拿到的名字

            const action = urlParams.get('action') || '';
            const typeParam = (urlParams.get('type') || '').toUpperCase();

            // 🎯 根據參數判斷該去正餐還是飲料頁面
            let targetPage = "order_ui.html"; // 預設去正餐 UI
            if (action === "order_drink_ui" || typeParam === "DRINK") {
                targetPage = "order_drink_ui.html"; // 去飲料 UI
            }

            // 🚀 直接在 GitHub 本地轉向目的地，不再繞回 GAS！
            window.location.replace(targetPage + '?' + urlParams.toString());
        }
        window.onload = init;
    </script>
</body>
</html>
