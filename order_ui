<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>訂餐</title>
  <style>
    :root { --primary: #00b900; --bg: #f4f4f4; --text: #333;
    }
    body { font-family: sans-serif; padding: 5px; background: var(--bg); color: var(--text); font-size: 25px; margin: 0;
    }
    .card { background: white; border-radius: 10px; padding: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); margin-bottom: 10px;
    }
    h2 { color: var(--primary); text-align: center; margin: 0 0 10px 0; font-size: 2.125rem;
    }
    .input-group { margin-bottom: 10px; }
    label { display: block; font-weight: 600; margin-bottom: 0;
    font-size: 1.625rem; }
    input[type="text"] { width: 100%; padding: 7.5px; border: 2.5px solid #ddd; border-radius: 5px; box-sizing: border-box;
    font-size: 1.875rem; }
    
    .menu-item { display: flex; align-items: center; padding: 7.5px 0;
    border-bottom: 2.5px solid #f9f9f9; }
    .item-info { flex: 1; min-width: 0; overflow: hidden;
    }
    .item-name { font-weight: 600; font-size: 2rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .item-price { color: #666; font-size: 1.625rem; }
    .qty-controls { display: flex; align-items: center;
    gap: 5px; }
    .btn-qty { background: #eee; border: 2.5px solid #ccc; width: 50px; height: 50px; border-radius: 50%;
    font-size: 2rem; cursor: pointer; }
    .qty-val { width: 50px; text-align: center; font-weight: bold; font-size: 2rem;
    }
    
    .btn-submit { background: var(--primary); color: white; border: none; padding: 12.5px; border-radius: 25px;
    font-size: 2rem; font-weight: 600; width: 100%; margin-top: 10px; }
    .btn-submit:disabled { background: #999;
    }
    
    table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 1.75rem; table-layout: fixed;
    }
    th, td { padding: 5px 2.5px; border-bottom: 2.5px solid #eee; overflow: hidden;
    }
    th:nth-child(1), td:nth-child(1) { width: 5.5em; text-align: left; }
    th:nth-child(2), td:nth-child(2) { text-align: left;
    }
    th:nth-child(3), td:nth-child(3) { width: 2em; text-align: right; }
    th:nth-child(4), td:nth-child(4) { width: 3em;
    text-align: right; }
    th:nth-child(5), td:nth-child(5) { width: 3.5em; text-align: center;
    }
    .btn-delete { background: #fcc; color: #a00; border: 2.5px solid #a00; padding: 0 10px; border-radius: 10px;
    font-size: 1.625rem; }
    .btn-delete:disabled { background: #eee; border-color: #ccc; color: #999;
    }
    
    /* 2倍大彈窗樣式 */
    .large-swal { font-size: 2rem !important;
    width: 90% !important; }
  </style>
</head>
<body>
  <div class="card">
    <h2 id="shop-title">🏪 載入中...</h2>
    <div class="input-group">
      <label>訂購人姓名： (訂購明細在最下方）</label>
      <input type="text" id="userName" value="" placeholder="請輸入名字" required>
    </div>

    <div id="menu-list">
      <div style="text-align:center; padding:20px;">正在讀取菜單...</div>
    </div>
    <div style="margin-top:15px; font-size: 2.5rem; font-weight: bold; color: #d32f2f; text-align: right;">總計：$<span id="total-price">0</span></div>
    <button type="button" id="submitBtn" class="btn-submit" onclick="submitForm()">送出訂單</button>
  </div>

  <div class="card">
    <h2 style="font-size: 2.125rem;">📊 目前訂單明細</h2>
    <table>
      <thead><tr><th>人名</th><th>餐點</th><th>數</th><th>金額</th><th>操作</th></tr></thead>
      <tbody id="history-body"><tr><td colspan="5">載入中...</td></tr></tbody>
    </table>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    // ==========================================
    // 🔑 您的 GAS 網頁應用程式 (Web App) 部署網址
    // ==========================================
    const GAS_WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbzhUln6Pkz83tH0tgZo43QNqbDutANsa0Jzrov-qspv5Zk-nJG8s_nc1_XirMW8pZsTxw/exec';

    // 從網址參數動態取得變數
    const urlParams = new URLSearchParams(window.location.search);
    const shopName = urlParams.get('shopName') || urlParams.get('shop') || "";
    const groupId = urlParams.get('groupId') || urlParams.get('gid') || "";
    const sessionId = urlParams.get('sessionId') || urlParams.get('sid') || "";
    const uName = urlParams.get('uName') || "";
    const orderType = urlParams.get('type') || "MEAL";

    let globalMenu = [];
    let quantities = [];

    window.onload = function() {
      if (shopName) {
        document.getElementById('shop-title').innerText = "🏪 " + shopName;
      }
      if (uName) {
        document.getElementById('userName').value = uName;
      }
      
      // 載入歷史紀錄與菜單
      loadHistory();
      fetchMenuFromGas();
    };

    // 透過 fetch 向 GAS 請求菜單資料
    function fetchMenuFromGas() {
      if (!shopName) {
        document.getElementById('menu-list').innerHTML = '<div style="text-align:center; padding:20px; color:red;">錯誤：未指定商店名稱</div>';
        return;
      }

      // 發送 GET 請求給 GAS doGet API 獲取菜單
      const fetchUrl = `${GAS_WEB_APP_URL}?action=get_menu_json&shop=${encodeURIComponent(shopName)}&type=${orderType}`;

      fetch(fetchUrl)
        .then(response => response.json())
        .then(menuData => {
          globalMenu = menuData || [];
          quantities = new Array(globalMenu.length).fill(0);
          renderMenu();
        })
        .catch(err => {
          document.getElementById('menu-list').innerHTML = '<div style="text-align:center; padding:20px; color:red;">讀取菜單失敗，請重新整理</div>';
          console.error("Fetch Menu Error: ", err);
        });
    }

    function renderMenu() {
      const list = document.getElementById('menu-list');
      if (globalMenu.length === 0) {
        list.innerHTML = '<div style="text-align:center; padding:20px;">此商店尚無菜單資料</div>';
        return;
      }
      list.innerHTML = globalMenu.map((item, index) => `
        <div class="menu-item">
          <div class="item-info">
            <div class="item-name">${item.name}</div>
            <div class="item-price">$${item.price}</div>
          </div>
          <div class="qty-controls">
            <button class="btn-qty" onclick="changeQty(${index}, -1)">-</button>
            <div class="qty-val" id="qty-${index}">0</div>
            <button class="btn-qty" onclick="changeQty(${index}, 1)">+</button>
          </div>
        </div>
      `).join('');
    }

    function changeQty(index, delta) {
      quantities[index] = Math.max(0, quantities[index] + delta);
      document.getElementById('qty-' + index).innerText = quantities[index];
      updateTotal();
    }
    
    function updateTotal() {
      let total = 0;
      quantities.forEach((qty, i) => { total += qty * globalMenu[i].price; });
      document.getElementById('total-price').innerText = total;
    }
    
    function submitForm() {
      const name = document.getElementById('userName').value.trim();
      if (!name) { Swal.fire('請先輸入姓名！'); return; }
      const orderData = [];
      quantities.forEach((q, i) => { if(q>0) orderData.push({name: globalMenu[i].name, price: globalMenu[i].price, qty: q}); });
      if (orderData.length === 0) { Swal.fire('請選擇餐點'); return; }

      let summaryText = orderData.map(o => `${o.name}*${o.qty}`).join('<br>');
      Swal.fire({
        title: '確認訂單內容',
        html: `訂購人：${name}<br><br><div style="text-align:left;">${summaryText}</div><br>總計：$${document.getElementById('total-price').innerText}`,
        customClass: { popup: 'large-swal' },
        showCancelButton: true,
        confirmButtonText: '確定送出',
        cancelButtonText: '取消'
      }).then((result) => {
        if (result.isConfirmed) {
          const btn = document.getElementById('submitBtn');
          btn.disabled = true;
          btn.innerText = "送出中...";

          // 使用 POST 請求發送到 GAS 的 doPost(e)
          const payload = {
            action: "processWebOrder",
            userName: name,
            groupId: groupId,
            sessionId: sessionId,
            orderData: orderData,
            type: orderType
          };

          fetch(`${GAS_WEB_APP_URL}?data=${encodeURIComponent(JSON.stringify(payload))}`, {
            method: 'POST'
          })
          .then(res => res.json())
          .then(resData => {
            if (resData.status === "success") {
              Swal.fire({ icon: 'success', title: '送出成功！', timer: 1000 });
              quantities.fill(0); 
              globalMenu.forEach((_, i) => document.getElementById('qty-'+i).innerText='0'); 
              updateTotal();
              loadHistory();
            } else {
              Swal.fire({ icon: 'error', title: '送出失敗: ' + (resData.message || '') });
            }
            btn.disabled = false;
            btn.innerText = "送出訂單";
          })
          .catch(err => {
            Swal.fire({ icon: 'error', title: '連線失敗，請再試一次' });
            btn.disabled = false;
            btn.innerText = "送出訂單";
          });
        }
      });
    }

    function deleteOrder(btn, userName, mealName) {
      Swal.fire({
        title: '確認刪除',
        html: `確定要刪除 ${userName} 的 ${mealName} 嗎？`,
        customClass: { popup: 'large-swal' },
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: '刪除',
        cancelButtonText: '取消'
      }).then((result) => {
        if (result.isConfirmed) {
          btn.disabled = true;
          btn.innerText = "刪除中...";

          const payload = {
            action: "deleteWebOrder",
            groupId: groupId,
            sessionId: sessionId,
            userName: userName,
            mealName: mealName,
            type: orderType
          };

          fetch(`${GAS_WEB_APP_URL}?data=${encodeURIComponent(JSON.stringify(payload))}`, {
            method: 'POST'
          })
          .then(res => res.json())
          .then(resData => {
            if (resData.status === "success") {
              loadHistory();
            } else {
              Swal.fire({ icon: 'error', title: '刪除失敗: ' + (resData.message || '') });
              btn.disabled = false;
              btn.innerText = "刪除";
            }
          })
          .catch(err => {
            btn.disabled = false;
            btn.innerText = "刪除";
          });
        }
      });
    }

    function loadHistory() {
      const fetchUrl = `${GAS_WEB_APP_URL}?action=get_orders_json&gid=${encodeURIComponent(groupId)}&sid=${encodeURIComponent(sessionId)}&type=${orderType}`;

      fetch(fetchUrl)
        .then(response => response.json())
        .then(data => {
          const body = document.getElementById('history-body');
          body.innerHTML = data.length === 0 ? '<tr><td colspan="5">無資料</td></tr>' : data.map(r => `<tr>
            <td>${r.user}</td><td>${r.meal}</td><td style="text-align:right;">${r.qty}</td><td style="text-align:right;">$${r.price * r.qty}</td>
            <td><button class="btn-delete" onclick="deleteOrder(this, '${r.user}', '${r.meal}')">刪除</button></td>
          </tr>`).join('');
        })
        .catch(err => {
          console.error("Fetch history error: ", err);
        });
    }
  </script>
</body>
</html>
